BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Calee Regression//REG-SUB fixture//EN
CALSCALE:GREGORIAN
X-WR-CALNAME:REG-SUB Regression Subscription
BEGIN:VEVENT
UID:reg-sub-allday-single@calee.regression
SUMMARY:REG-SUB-ALLDAY-SINGLE
DTSTART;VALUE=DATE:20260805
DTEND;VALUE=DATE:20260806
DESCRIPTION:Single-day all-day event. DTEND is exclusive (20260806), so it is visible only on 2026-08-05.
END:VEVENT
BEGIN:VEVENT
UID:reg-sub-allday-multi@calee.regression
SUMMARY:REG-SUB-ALLDAY-MULTI
DTSTART;VALUE=DATE:20260810
DTEND;VALUE=DATE:20260813
DESCRIPTION:Multi-day all-day event spanning 2026-08-10..2026-08-12 inclusive. DTEND exclusive (20260813).
END:VEVENT
BEGIN:VEVENT
UID:reg-sub-timed@calee.regression
SUMMARY:REG-SUB-TIMED
DTSTART:20260806T090000Z
DTEND:20260806T100000Z
DESCRIPTION:Timed event, 09:00-10:00Z on 2026-08-06 (one hour, not all-day).
END:VEVENT
BEGIN:VEVENT
UID:reg-sub-bare-allday@calee.regression
SUMMARY:REG-SUB-BARE-ALLDAY
DTSTART:20260808
DTEND:20260809
DESCRIPTION:Bare DTSTART:YYYYMMDD with NO VALUE=DATE parameter. Must still be treated as all-day (hub-core rule) and visible only on 2026-08-08.
END:VEVENT
BEGIN:VEVENT
UID:reg-sub-allday-daily@calee.regression
SUMMARY:REG-SUB-ALLDAY-DAILY
DTSTART;VALUE=DATE:20260820
DTEND;VALUE=DATE:20260821
RRULE:FREQ=DAILY;COUNT=5
EXDATE;VALUE=DATE:20260822
DESCRIPTION:Daily recurring all-day event, 5 occurrences 2026-08-20..2026-08-24, with 2026-08-22 removed by EXDATE and 2026-08-23 replaced by the override below.
END:VEVENT
BEGIN:VEVENT
UID:reg-sub-allday-daily@calee.regression
SUMMARY:REG-SUB-OVERRIDE
RECURRENCE-ID;VALUE=DATE:20260823
DTSTART;VALUE=DATE:20260823
DTEND;VALUE=DATE:20260824
DESCRIPTION:Recurrence override: replaces the 2026-08-23 occurrence of REG-SUB-ALLDAY-DAILY, renaming it REG-SUB-OVERRIDE.
END:VEVENT
END:VCALENDAR
